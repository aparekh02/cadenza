<mujoco model="go1">
  <!--
    Unitree Go1 — MuJoCo model (corrected joint axes)
    Joint axis convention matches cadenza.locomotion.robot_spec FK formula:
      thigh/calf: axis="0 -1 0"  so Ry(-q) matches spec's Ry(-q_thigh)
      hip FL/RL:  axis="1  0 0"  (hs=+1)
      hip FR/RR:  axis="-1 0 0"  (hs=-1)
    All ref="0". Stand pose qpos=(0, 0.9, -1.8) per leg gives foot at ~-0.265m from CoM.
    Physics: thigh=calf=0.213m | max_torque=33.5Nm | total_mass=12kg
  -->

  <compiler angle="radian" autolimits="true"/>
  <option gravity="0 0 -9.81" timestep="0.002" iterations="50" tolerance="1e-10"/>

  <default>
    <joint damping="0.08" frictionloss="0.02" armature="0.01"/>
    <geom contype="1" conaffinity="1" condim="3"
          friction="0.8 0.02 0.001" solref="0.005 1" solimp="0.98 0.99 0.001"/>
    <motor gear="1" ctrllimited="true" ctrlrange="-33.5 33.5"/>
  </default>

  <asset>
    <texture type="skybox" builtin="gradient"
             rgb1="0.05 0.05 0.12" rgb2="0.18 0.18 0.30" width="512" height="512"/>
    <texture name="checker" type="2d" builtin="checker"
             rgb1="0.10 0.10 0.16" rgb2="0.16 0.16 0.24" width="512" height="512"/>
    <material name="floor_mat"  texture="checker" texrepeat="6 6" texuniform="true" reflectance="0.05"/>
    <material name="body_mat"   rgba="0.28 0.28 0.35 1"/>
    <material name="leg_mat"    rgba="0.22 0.22 0.28 1"/>
  </asset>

  <worldbody>
    <light name="sun"  pos="2 2 8"  dir="-0.2 -0.2 -1" diffuse="0.8 0.8 1.0" castshadow="true"/>
    <light name="fill" pos="-3 -2 4" dir="1 0.5 -1"   diffuse="0.3 0.3 0.4"  castshadow="false"/>

    <!-- Ground -->
    <geom name="floor" type="plane" size="30 30 0.1" material="floor_mat" condim="3" friction="0.8 0.02 0.001"/>

    <!-- ── Jump task layout ────────────────────────────────────────────── -->
    <!-- Approach ramp: slight texture change before hurdle -->
    <geom name="gravel_approach" type="box" size="1.5 1.5 0.004" pos="2.5 0 0.004"
          rgba="0.38 0.30 0.18 1" friction="0.85 0.02 0.001"/>

    <!-- Hurdle: 10 cm tall obstacle the robot must bound over -->
    <geom name="hurdle" type="box" size="0.10 1.5 0.05" pos="4.0 0 0.05"
          rgba="0.90 0.35 0.10 1" friction="0.9 0.02 0.001"/>

    <!-- Goal platform: slightly raised, green tint — reach here to succeed -->
    <geom name="goal_pad" type="box" size="1.5 1.5 0.025" pos="8.0 0 0.025"
          rgba="0.15 0.80 0.30 0.85" friction="0.9 0.02 0.001"/>

    <!-- Goal marker post (visual reference) -->
    <geom name="goal_post" type="cylinder" size="0.03 0.30" pos="8.0 0 0.33"
          rgba="0.15 0.90 0.30 0.9"/>

    <!-- ══ Robot trunk ═══════════════════════════════════════════════════ -->
    <body name="trunk" pos="0 0 0.32">
      <freejoint name="root"/>
      <geom name="trunk" type="box" size="0.1881 0.0475 0.048"
            mass="9.041" material="body_mat"/>
      <site name="imu" pos="0 0 0" size="0.005"/>

      <!-- ── FL leg ──────────────────────────────────────────────────── -->
      <body name="FL_hip" pos="0.1881 0.0472 0">
        <joint name="FL_hip_joint" type="hinge" axis="1 0 0"
               range="-0.863 0.863"/>
        <geom type="capsule" size="0.044 0.020" pos="0 0.040 0"
              euler="1.5708 0 0" mass="0.591" material="body_mat"/>
        <body name="FL_thigh" pos="0 0.0838 0">
          <joint name="FL_thigh_joint" type="hinge" axis="0 -1 0"
                 range="-0.686 4.501"/>
          <geom type="capsule" size="0.025" fromto="0 0 0 0 0 -0.213"
                mass="0.921" material="leg_mat" rgba="0.30 0.55 0.90 1"/>
          <body name="FL_calf" pos="0 0 -0.213">
            <joint name="FL_calf_joint" type="hinge" axis="0 -1 0"
                   range="-2.818 -0.888"/>
            <geom type="capsule" size="0.019" fromto="0 0 0 0 0 -0.213"
                  mass="0.135" material="leg_mat"/>
            <body name="FL_foot" pos="0 0 -0.213">
              <geom name="FL_foot_geom" type="sphere" size="0.0165"
                    mass="0.06" rgba="0.30 0.55 0.90 1"/>
            </body>
          </body>
        </body>
      </body>

      <!-- ── FR leg ──────────────────────────────────────────────────── -->
      <body name="FR_hip" pos="0.1881 -0.0472 0">
        <joint name="FR_hip_joint" type="hinge" axis="-1 0 0"
               range="-0.863 0.863"/>
        <geom type="capsule" size="0.044 0.020" pos="0 -0.040 0"
              euler="1.5708 0 0" mass="0.591" material="body_mat"/>
        <body name="FR_thigh" pos="0 -0.0838 0">
          <joint name="FR_thigh_joint" type="hinge" axis="0 -1 0"
                 range="-0.686 4.501"/>
          <geom type="capsule" size="0.025" fromto="0 0 0 0 0 -0.213"
                mass="0.921" material="leg_mat" rgba="0.90 0.33 0.33 1"/>
          <body name="FR_calf" pos="0 0 -0.213">
            <joint name="FR_calf_joint" type="hinge" axis="0 -1 0"
                   range="-2.818 -0.888"/>
            <geom type="capsule" size="0.019" fromto="0 0 0 0 0 -0.213"
                  mass="0.135" material="leg_mat"/>
            <body name="FR_foot" pos="0 0 -0.213">
              <geom name="FR_foot_geom" type="sphere" size="0.0165"
                    mass="0.06" rgba="0.90 0.33 0.33 1"/>
            </body>
          </body>
        </body>
      </body>

      <!-- ── RL leg ──────────────────────────────────────────────────── -->
      <body name="RL_hip" pos="-0.1881 0.0472 0">
        <joint name="RL_hip_joint" type="hinge" axis="1 0 0"
               range="-0.863 0.863"/>
        <geom type="capsule" size="0.044 0.020" pos="0 0.040 0"
              euler="1.5708 0 0" mass="0.591" material="body_mat"/>
        <body name="RL_thigh" pos="0 0.0838 0">
          <joint name="RL_thigh_joint" type="hinge" axis="0 -1 0"
                 range="-0.686 4.501"/>
          <geom type="capsule" size="0.025" fromto="0 0 0 0 0 -0.213"
                mass="0.921" material="leg_mat" rgba="0.30 0.90 0.75 1"/>
          <body name="RL_calf" pos="0 0 -0.213">
            <joint name="RL_calf_joint" type="hinge" axis="0 -1 0"
                   range="-2.818 -0.888"/>
            <geom type="capsule" size="0.019" fromto="0 0 0 0 0 -0.213"
                  mass="0.135" material="leg_mat"/>
            <body name="RL_foot" pos="0 0 -0.213">
              <geom name="RL_foot_geom" type="sphere" size="0.0165"
                    mass="0.06" rgba="0.30 0.90 0.75 1"/>
            </body>
          </body>
        </body>
      </body>

      <!-- ── RR leg ──────────────────────────────────────────────────── -->
      <body name="RR_hip" pos="-0.1881 -0.0472 0">
        <joint name="RR_hip_joint" type="hinge" axis="-1 0 0"
               range="-0.863 0.863"/>
        <geom type="capsule" size="0.044 0.020" pos="0 -0.040 0"
              euler="1.5708 0 0" mass="0.591" material="body_mat"/>
        <body name="RR_thigh" pos="0 -0.0838 0">
          <joint name="RR_thigh_joint" type="hinge" axis="0 -1 0"
                 range="-0.686 4.501"/>
          <geom type="capsule" size="0.025" fromto="0 0 0 0 0 -0.213"
                mass="0.921" material="leg_mat" rgba="0.90 0.65 0.30 1"/>
          <body name="RR_calf" pos="0 0 -0.213">
            <joint name="RR_calf_joint" type="hinge" axis="0 -1 0"
                   range="-2.818 -0.888"/>
            <geom type="capsule" size="0.019" fromto="0 0 0 0 0 -0.213"
                  mass="0.135" material="leg_mat"/>
            <body name="RR_foot" pos="0 0 -0.213">
              <geom name="RR_foot_geom" type="sphere" size="0.0165"
                    mass="0.06" rgba="0.90 0.65 0.30 1"/>
            </body>
          </body>
        </body>
      </body>

    </body><!-- /trunk -->
  </worldbody>

  <actuator>
    <motor name="FL_hip"   joint="FL_hip_joint"   ctrlrange="-33.5 33.5"/>
    <motor name="FL_thigh" joint="FL_thigh_joint" ctrlrange="-33.5 33.5"/>
    <motor name="FL_calf"  joint="FL_calf_joint"  ctrlrange="-33.5 33.5"/>
    <motor name="FR_hip"   joint="FR_hip_joint"   ctrlrange="-33.5 33.5"/>
    <motor name="FR_thigh" joint="FR_thigh_joint" ctrlrange="-33.5 33.5"/>
    <motor name="FR_calf"  joint="FR_calf_joint"  ctrlrange="-33.5 33.5"/>
    <motor name="RL_hip"   joint="RL_hip_joint"   ctrlrange="-33.5 33.5"/>
    <motor name="RL_thigh" joint="RL_thigh_joint" ctrlrange="-33.5 33.5"/>
    <motor name="RL_calf"  joint="RL_calf_joint"  ctrlrange="-33.5 33.5"/>
    <motor name="RR_hip"   joint="RR_hip_joint"   ctrlrange="-33.5 33.5"/>
    <motor name="RR_thigh" joint="RR_thigh_joint" ctrlrange="-33.5 33.5"/>
    <motor name="RR_calf"  joint="RR_calf_joint"  ctrlrange="-33.5 33.5"/>
  </actuator>

</mujoco>
